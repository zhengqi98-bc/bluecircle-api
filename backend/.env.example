# Render auto-injects DATABASE_URL when you link a PostgreSQL database.
# These are the only env vars you need to set manually:

# CORS — set to your Hostinger domain (e.g. https://yourdomain.com)
CORS_ORIGINS=https://YOUR_DOMAIN.com

# JWT secret — Render will auto-generate this if set in render.yaml
JWT_SECRET=change-me-to-a-random-string
